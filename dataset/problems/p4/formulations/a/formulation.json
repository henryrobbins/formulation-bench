{
    "valid": true,
    "parameters": {
        "CarCapacity": {
            "description": "The number of employees that a car can take",
            "type": "integer",
            "shape": []
        },
        "CarPollution": {
            "description": "The pollution produced by a car",
            "type": "continuous",
            "shape": []
        },
        "BusCapacity": {
            "description": "The number of employees that a bus can take",
            "type": "integer",
            "shape": []
        },
        "BusPollution": {
            "description": "The pollution produced by a bus",
            "type": "continuous",
            "shape": []
        },
        "MinEmployeesToTransport": {
            "description": "The minimum number of employees that need to be transported",
            "type": "continuous",
            "shape": []
        },
        "MaxBuses": {
            "description": "The maximum number of buses that can be used",
            "type": "continuous",
            "shape": []
        }
    },
    "assumptions": [
        {
            "description": "The number of employees that a car can take must be non-negative.",
            "formulation": "CarCapacity \\geq 0",
            "explicit": false,
            "code": {
                "python": "assert CarCapacity >= 0"
            }
        },
        {
            "description": "The pollution produced by a car must be non-negative.",
            "formulation": "CarPollution \\geq 0",
            "explicit": false,
            "code": {
                "python": "assert CarPollution >= 0"
            }
        },
        {
            "description": "The number of employees that a bus can take must be non-negative.",
            "formulation": "BusCapacity \\geq 0",
            "explicit": false,
            "code": {
                "python": "assert BusCapacity >= 0"
            }
        },
        {
            "description": "The pollution produced by a bus must be non-negative.",
            "formulation": "BusPollution \\geq 0",
            "explicit": false,
            "code": {
                "python": "assert BusPollution >= 0"
            }
        },
        {
            "description": "The minimum number of employees that need to be transported must be non-negative.",
            "formulation": "MinEmployeesToTransport \\geq 0",
            "explicit": false,
            "code": {
                "python": "assert MinEmployeesToTransport >= 0"
            }
        },
        {
            "description": "The maximum number of buses that can be used must be non-negative.",
            "formulation": "MaxBuses \\geq 0",
            "explicit": false,
            "code": {
                "python": "assert MaxBuses >= 0"
            }
        }
    ],
    "variables": {
        "xCars": {
            "description": "The number of cars used for transportation",
            "type": "integer",
            "shape": []
        },
        "xBuses": {
            "description": "The number of buses used for transportation",
            "type": "integer",
            "shape": []
        }
    },
    "constraints": [
        {
            "description": "At least MinEmployeesToTransport employees must be transported.",
            "formulation": "xCars \\times CarCapacity + xBuses \\times BusCapacity \\geq MinEmployeesToTransport",
            "explicit": true,
            "code": {
                "gurobipy": "model.addConstr(xCars * CarCapacity + xBuses * BusCapacity >= MinEmployeesToTransport)"
            }
        },
        {
            "description": "No more than MaxBuses buses can be used.",
            "formulation": "xBuses \\leq MaxBuses",
            "explicit": true,
            "code": {
                "gurobipy": "model.addConstr(xBuses <= MaxBuses)"
            }
        },
        {
            "description": "Number of cars used is non-negative.",
            "formulation": "xCars \\geq 0",
            "explicit": false,
            "code": {
                "gurobipy": "model.addConstr(xCars >= 0)"
            }
        },
        {
            "description": "Number of buses used is non-negative.",
            "formulation": "xBuses \\geq 0",
            "explicit": false,
            "code": {
                "gurobipy": "model.addConstr(xBuses >= 0)"
            }
        }
    ],
    "objective": {
        "description": "Total pollution produced is the sum of pollution from cars and buses. The objective is to minimize the total pollution produced.",
        "formulation": "Min \\ xCars \\times CarPollution + xBuses \\times BusPollution",
        "code": {
            "gurobipy": "model.setObjective(xCars * CarPollution + xBuses * BusPollution, GRB.MINIMIZE)"
        }
    },
