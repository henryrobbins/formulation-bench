{
    "name": "Capacitated Warehouse Location Problem (CWLP)",
    "parameters": {
        "n": {
            "description": "Number of customers",
            "type": "integer",
            "shape": []
        },
        "m": {
            "description": "Number of candidate warehouses",
            "type": "integer",
            "shape": []
        },
        "d": {
            "description": "Demand of each customer",
            "type": "continuous",
            "shape": [
                "n"
            ]
        },
        "u": {
            "description": "Capacity of each warehouse",
            "type": "continuous",
            "shape": [
                "m"
            ]
        },
        "f": {
            "description": "Fixed cost to open each warehouse",
            "type": "continuous",
            "shape": [
                "m"
            ]
        },
        "c": {
            "description": "Transportation cost from each warehouse to each customer",
            "type": "continuous",
            "shape": [
                "n",
                "m"
            ]
        }
    },
    "metadata": {
        "source": {
            "dataset": "EvoCut"
        },
        "notes": [
            "We add implicit assumptions that $|I|, |J| > 0$, $u, f, c \\geq 0$, and $d > 0$.",
            "$d > 0$ is necessary for arguing $x_{ij} = 0$ when $y_j = 0$.",
            "EvoCut arXiv submission `v1` proposes a hybrid inequality combining three lower bounds. We split this hybrid inequality into three separate inequalities to generate formulations `p6.b-d`.",
            "EvoCut arXiv submission `v2` proposes a family of inequalities used to generate formulations `p6.e-j`."
        ]
    }
}
