{
    "valid": true,
    "parameters": {
        "WaterSubsoil": {
            "description": "Amount of water required to hydrate one bag of subsoil per day",
            "type": "continuous",
            "shape": []
        },
        "WaterTopsoil": {
            "description": "Amount of water required to hydrate one bag of topsoil per day",
            "type": "continuous",
            "shape": []
        },
        "MaxTotalBags": {
            "description": "Maximum number of bags of topsoil and subsoil combined",
            "type": "integer",
            "shape": []
        },
        "MinTopsoilBags": {
            "description": "Minimum number of topsoil bags to be used",
            "type": "integer",
            "shape": []
        },
        "MaxTopsoilProportion": {
            "description": "Maximum proportion of bags that can be topsoil",
            "type": "continuous",
            "shape": []
        }
    },
    "assumptions": [
        {
            "description": "The amount of water required to hydrate one bag of subsoil per day must be non-negative.",
            "formulation": "WaterSubsoil \\geq 0",
            "explicit": false,
            "code": {
                "python": "assert WaterSubsoil >= 0"
            }
        },
        {
            "description": "The amount of water required to hydrate one bag of topsoil per day must be non-negative.",
            "formulation": "WaterTopsoil \\geq 0",
            "explicit": false,
            "code": {
                "python": "assert WaterTopsoil >= 0"
            }
        },
        {
            "description": "The maximum number of bags of topsoil and subsoil combined must be non-negative.",
            "formulation": "MaxTotalBags \\geq 0",
            "explicit": false,
            "code": {
                "python": "assert MaxTotalBags >= 0"
            }
        },
        {
            "description": "The minimum number of topsoil bags to be used must be non-negative.",
            "formulation": "MinTopsoilBags \\geq 0",
            "explicit": false,
            "code": {
                "python": "assert MinTopsoilBags >= 0"
            }
        },
        {
            "description": "The maximum proportion of bags that can be topsoil must be non-negative.",
            "formulation": "MaxTopsoilProportion \\geq 0",
            "explicit": false,
            "code": {
                "python": "assert MaxTopsoilProportion >= 0"
            }
        }
    ],
    "variables": {
        "SubsoilBags": {
            "description": "The number of subsoil bags",
            "type": "integer",
            "shape": []
        },
        "TopsoilBags": {
            "description": "The number of topsoil bags",
            "type": "integer",
            "shape": []
        }
    },
    "constraints": [
        {
            "description": "The total number of subsoil and topsoil bags combined must not exceed MaxTotalBags.",
            "formulation": "SubsoilBags + TopsoilBags \\leq MaxTotalBags",
            "explicit": true,
            "code": {
                "gurobipy": "model.addConstr(SubsoilBags + TopsoilBags <= MaxTotalBags)"
            }
        },
        {
            "description": "At least MinTopsoilBags bags of topsoil must be used.",
            "formulation": "TopsoilBags \\geq MinTopsoilBags",
            "explicit": true,
            "code": {
                "gurobipy": "model.addConstr(TopsoilBags >= MinTopsoilBags)"
            }
        },
        {
            "description": "The proportion of topsoil bags must not exceed MaxTopsoilProportion of all bags.",
            "formulation": "TopsoilBags \\leq MaxTopsoilProportion \\times ( TopsoilBags + SubsoilBags )",
            "explicit": true,
            "code": {
                "gurobipy": "model.addConstr(TopsoilBags <= MaxTopsoilProportion * (TopsoilBags + SubsoilBags))"
            }
        },
        {
            "description": "The number of subsoil bags must be non-negative.",
            "formulation": "SubsoilBags \\geq 0",
            "explicit": true,
            "code": {
                "gurobipy": "model.addConstr(SubsoilBags >= 0)"
            }
        },
        {
            "description": "The number of topsoil bags must be non-negative.",
            "formulation": "TopsoilBags \\geq 0",
            "explicit": true,
            "code": {
                "gurobipy": "model.addConstr(TopsoilBags >= 0)"
            }
        }
    ],
    "objective": {
        "description": "Total water required is the sum of (WaterSubsoil * number of subsoil bags) and (WaterTopsoil * number of topsoil bags). The objective is to minimize the total water required.",
        "formulation": "Min \\left( WaterSubsoil \\times SubsoilBags + WaterTopsoil \\times TopsoilBags \\right )",
        "code": {
            "gurobipy": "model.setObjective(WaterSubsoil * SubsoilBags + WaterTopsoil * TopsoilBags, GRB.MINIMIZE)"
        }
    },
    "metadata": {
        "source": {
            "dataset": "EquivaFormulation",
