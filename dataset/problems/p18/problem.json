{
    "name": "Timor-Leste Hospital Location",
    "parameters": {
        "nI": {
            "description": "Number of household clusters",
            "type": "integer",
            "shape": []
        },
        "m": {
            "description": "Number of existing hospitals",
            "type": "integer",
            "shape": []
        },
        "M": {
            "description": "Total number of candidate hospital sites (including existing hospitals)",
            "type": "integer",
            "shape": []
        },
        "v": {
            "description": "Population of each household cluster",
            "type": "continuous",
            "shape": [
                "nI"
            ]
        },
        "d": {
            "description": "Travel distance from each household to each hospital site",
            "type": "continuous",
            "shape": [
                "nI",
                "M"
            ]
        },
        "S": {
            "description": "Maximum allowed travel distance from household to hospital",
            "type": "continuous",
            "shape": []
        },
        "p": {
            "description": "Maximum number of new hospitals that can be opened",
            "type": "integer",
            "shape": []
        }
    },
    "metadata": {
        "source": {
            "dataset": "Ferchtandiker2025"
        },
        "notes": [
            "We add implicit assumptions that all sets are non-empty, $v_i, p, M \\geq 0$ and $m \\leq M$."
        ]
    }
}
