{
    "name": "Multi-Commodity Network Design (MCND)",
    "parameters": {
        "n": {
            "description": "Number of network nodes",
            "type": "integer",
            "shape": []
        },
        "m": {
            "description": "Number of candidate directed arcs",
            "type": "integer",
            "shape": []
        },
        "K": {
            "description": "Number of commodities",
            "type": "integer",
            "shape": []
        },
        "tail": {
            "description": "Source node index of each arc",
            "type": "continuous",
            "shape": [
                "m"
            ]
        },
        "head": {
            "description": "Destination node index of each arc",
            "type": "continuous",
            "shape": [
                "m"
            ]
        },
        "c": {
            "description": "Unit transportation cost on each arc",
            "type": "continuous",
            "shape": [
                "m"
            ]
        },
        "f": {
            "description": "Fixed cost to activate each arc",
            "type": "continuous",
            "shape": [
                "m"
            ]
        },
        "u": {
            "description": "Capacity of each arc",
            "type": "continuous",
            "shape": [
                "m"
            ]
        },
        "O": {
            "description": "Origin node of each commodity",
            "type": "continuous",
            "shape": [
                "K"
            ]
        },
        "D": {
            "description": "Destination node of each commodity",
            "type": "continuous",
            "shape": [
                "K"
            ]
        },
        "d": {
            "description": "Demand of each commodity",
            "type": "continuous",
            "shape": [
                "K"
            ]
        }
    },
    "metadata": {
        "source": {
            "dataset": "EvoCut"
        },
        "notes": [
            "We add implicit assumptions that $c_a, f_a, u_a \\ge 0$ and $d_k > 0$.",
            "$d_k > 0$ is necessary to eliminate degenerate cases and argue at least once entering arc to $D_k$ should be active.",
            "EvoCut arXiv submissions `v1` proposes one inequality used to generate formulation `p9.b`.",
            "EvoCut arXiv submissions `v2` proposes two inequalities used to generate formulations `p9.c` and `p9.d`."
        ]
    }
}
